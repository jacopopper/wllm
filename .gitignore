# Benchmarking study (analysis of external white-box UQ/hallucination methods)
# Keep curated analysis docs; ignore generated artifacts and large clones.
benchmarking/*-artifacts/
benchmarking/tmp/
benchmarking/**/artifacts/
benchmarking/**/__pycache__/

# Planning and local notes (do not ship these with the open library)
first-version-safety-researcher-library-plan.md
*plan.md
*TODO*.md
*scratch*.md

# Curated documentation that *should* ship
# (everything else .md is treated as local by default above)
# Root README and selected benchmarking study docs are allowed via negation below
!/README.md
!/benchmarking/README.md
!/benchmarking/gaps_and_recommendations.md
!/benchmarking/vllm_transparency_sketches.md
!/benchmarking/methods/*/README.md
!/CHANGELOG.md  # already versioned, but explicit in case

